---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ConsultaForm from '../components/ConsultaForm.astro';
import { pagesCentrales, getPageBySlug, getRelatedPages, site, iconForCategory } from '../data/datos.js';

export function getStaticPaths() {
  return pagesCentrales.map(p => ({
    params: { slug: p.slug },
    props: { page: p },
  }));
}

const { page } = Astro.props;
const related = getRelatedPages(page.slug, 7);

// Slugs donde queremos mostrar el formulario de consulta al inicio del article-main
const SLUGS_CON_FORM = ['consulta-ciudadana', 'consulta-por-placa', 'consulta-por-niv'];
const showForm = SLUGS_CON_FORM.includes(page.slug);

// Tab por defecto según el slug
const defaultTab = page.slug === 'consulta-por-niv' ? 'niv' : 'placa';

// "Próximos pasos" — varían por intención (slug o categoría)
const NEXT_STEPS_BY_SLUG: Record<string, { title: string, items: { label: string, href: string, icon: string, desc: string }[] }> = {
  'consulta-ciudadana': {
    title: '¿Qué hacer después de consultar?',
    items: [
      { label: 'Si aparece con reporte de robo', href: '/auto-robado/', icon: 'fa-triangle-exclamation', desc: 'No compres y denuncia' },
      { label: 'Si está limpio y vas a comprarlo', href: '/pasos-comprar-auto-usado/', icon: 'fa-list-check', desc: 'Checklist completo de compra' },
      { label: 'Cambio de propietario', href: '/cambio-propietario/', icon: 'fa-id-card', desc: 'Trámite legal al comprar' },
    ]
  },
  'consulta-por-placa': {
    title: 'Próximos pasos',
    items: [
      { label: 'Consulta también por NIV', href: '/consulta-por-niv/', icon: 'fa-barcode', desc: 'Verificación cruzada' },
      { label: 'Si compras el auto', href: '/pasos-comprar-auto-usado/', icon: 'fa-list-check', desc: 'Guía paso a paso' },
      { label: 'Historial vehicular completo', href: '/historial-vehicular/', icon: 'fa-clock-rotate-left', desc: 'Cómo obtenerlo' },
    ]
  },
  'consulta-por-niv': {
    title: 'Próximos pasos',
    items: [
      { label: '¿Dónde encontrar el NIV?', href: '/donde-esta-niv/', icon: 'fa-search', desc: 'Ubicación en el vehículo' },
      { label: '¿Qué significa cada estatus?', href: '/auto-no-aparece-repuve/', icon: 'fa-circle-question', desc: 'Posibles resultados' },
      { label: 'Pasos para comprar usado', href: '/pasos-comprar-auto-usado/', icon: 'fa-list-check', desc: 'Guía completa' },
    ]
  },
  'agendar-cita': {
    title: 'Después de agendar tu cita',
    items: [
      { label: 'Ver requisitos a llevar', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Documentos necesarios' },
      { label: 'Costos del trámite', href: '/costos/', icon: 'fa-coins', desc: 'Pagos y montos 2026' },
      { label: '¿Cómo llegar?', href: '/como-llegar/', icon: 'fa-route', desc: 'Transporte y mapa' },
    ]
  },
  'requisitos': {
    title: 'Próximos pasos',
    items: [
      { label: 'Agendá tu cita', href: '/agendar-cita/', icon: 'fa-calendar-check', desc: 'Reservá turno online' },
      { label: 'Conocé los costos', href: '/costos/', icon: 'fa-coins', desc: 'Precios actualizados 2026' },
      { label: 'Encontrá la oficina más cercana', href: '/oficinas/', icon: 'fa-location-dot', desc: '7 oficinas en Saltillo' },
    ]
  },
  'costos': {
    title: 'Próximos pasos',
    items: [
      { label: 'Documentos necesarios', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Qué llevar a la oficina' },
      { label: 'Agendá tu cita', href: '/agendar-cita/', icon: 'fa-calendar-check', desc: 'Reservá turno online' },
      { label: 'Adeudos vehiculares', href: '/adeudos-vehiculares/', icon: 'fa-money-bill-wave', desc: 'Verificá pendientes' },
    ]
  },
  'auto-robado': {
    title: 'Si te robaron el auto',
    items: [
      { label: 'Reporte de robo paso a paso', href: '/reporte-robo-vehicular/', icon: 'fa-file-shield', desc: 'Denuncia + REPUVE' },
      { label: 'Verificá si tu auto fue recuperado', href: '/vehiculos-recuperados/', icon: 'fa-car-side', desc: 'Lista de recuperados' },
      { label: 'Consulta REPUVE', href: '/consulta-ciudadana/', icon: 'fa-magnifying-glass', desc: 'Verificá el estatus' },
    ]
  },
  'regularizacion-autos-chocolate': {
    title: 'Próximos pasos',
    items: [
      { label: 'Oficina más cercana', href: '/oficinas/ciudad-juarez/', icon: 'fa-location-dot', desc: 'Saltillo (frontera)' },
      { label: 'Documentos requeridos', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Lista completa' },
      { label: 'Chip REPUVE', href: '/chip-repuve/', icon: 'fa-microchip', desc: 'Después de regularizar' },
    ]
  },
  'inscribir-vehiculo': {
    title: 'Próximos pasos',
    items: [
      { label: 'Documentos requeridos', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Lista completa' },
      { label: 'Costos del trámite', href: '/costos/', icon: 'fa-coins', desc: 'Precios 2026' },
      { label: 'Chip REPUVE', href: '/chip-repuve/', icon: 'fa-microchip', desc: 'Instalación gratuita' },
    ]
  },
  'cambio-propietario': {
    title: 'Próximos pasos',
    items: [
      { label: 'Antes: consultá el REPUVE', href: '/consulta-ciudadana/', icon: 'fa-magnifying-glass', desc: 'Verificá el vehículo' },
      { label: 'Verificá adeudos', href: '/adeudos-vehiculares/', icon: 'fa-money-bill-wave', desc: 'Multas y refrendos' },
      { label: 'Documentos necesarios', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Factura, INE, CURP' },
    ]
  },
  'que-es-niv': {
    title: 'Próximos pasos',
    items: [
      { label: '¿Dónde está el NIV en mi auto?', href: '/donde-esta-niv/', icon: 'fa-search', desc: 'Ubicaciones típicas' },
      { label: 'Consultá por NIV', href: '/consulta-por-niv/', icon: 'fa-magnifying-glass', desc: 'Verificación REPUVE' },
      { label: 'Historial vehicular', href: '/historial-vehicular/', icon: 'fa-clock-rotate-left', desc: 'Reporte completo' },
    ]
  },
};

// Default next steps por categoría si no hay slug-specific
const NEXT_STEPS_BY_CATEGORY: Record<string, { title: string, items: { label: string, href: string, icon: string, desc: string }[] }> = {
  'Tramite': {
    title: 'Próximos pasos',
    items: [
      { label: 'Documentos requeridos', href: '/requisitos/', icon: 'fa-folder-open', desc: 'Qué llevar a la oficina' },
      { label: 'Costos actualizados', href: '/costos/', icon: 'fa-coins', desc: 'Precios 2026' },
      { label: 'Oficinas en Saltillo', href: '/oficinas/', icon: 'fa-location-dot', desc: '7 sedes en el estado' },
    ]
  },
  'Consulta': {
    title: 'Próximos pasos',
    items: [
      { label: 'Pasos para comprar usado', href: '/pasos-comprar-auto-usado/', icon: 'fa-list-check', desc: 'Guía completa' },
      { label: 'Cambio de propietario', href: '/cambio-propietario/', icon: 'fa-id-card', desc: 'Trámite legal' },
      { label: 'Si aparece con reporte', href: '/auto-robado/', icon: 'fa-triangle-exclamation', desc: 'Qué hacer' },
    ]
  },
  'Informacion': {
    title: 'Relacionado',
    items: [
      { label: 'Consulta REPUVE gratis', href: '/consulta-ciudadana/', icon: 'fa-magnifying-glass', desc: 'En 2 minutos' },
      { label: 'Oficinas en Saltillo', href: '/oficinas/', icon: 'fa-location-dot', desc: '7 sedes disponibles' },
      { label: 'Preguntas frecuentes', href: '/preguntas-frecuentes/', icon: 'fa-circle-question', desc: 'Dudas comunes' },
    ]
  },
};

const nextSteps = NEXT_STEPS_BY_SLUG[page.slug] || NEXT_STEPS_BY_CATEGORY[page.category] || NEXT_STEPS_BY_CATEGORY['Informacion'];

// Punto medio del contenido para insertar CTA intermedio
const sectionsCount = page.sections ? page.sections.length : 0;
const ctaInsertAt = Math.floor(sectionsCount / 2);

// Build FAQ schema if has faqs
const schemas = [];
if (page.faqs && page.faqs.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": page.faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  });
}

// ============================================================
// HowTo schemas (solo en páginas que son procesos paso a paso)
// Aunque Google retiró el rich result de HowTo en sep-2023,
// el schema sigue siendo señal semántica fuerte para el motor.
// ============================================================
const HOWTO_BY_SLUG: Record<string, any> = {
  'consulta-ciudadana': {
    name: "Cómo consultar el REPUVE de un vehículo gratis en Saltillo",
    description: "Verificá el estatus legal de cualquier vehículo (reporte de robo, alertas) en menos de 2 minutos, gratis, desde el portal oficial del Gobierno de México.",
    totalTime: "PT2M",
    estimatedCost: { currency: "MXN", value: "0" },
    supply: ["Número de placa (5-7 caracteres)", "o NIV/VIN (17 caracteres)", "o folio de constancia"],
    tool: ["Computadora o celular con internet", "Navegador web"],
    steps: [
      { name: "Ingresar al portal oficial REPUVE", text: "Andá a https://www2.repuve.gob.mx:8443/ciudadania/. Es el único sitio oficial. Cualquier sitio que cobre por la consulta es fraude." },
      { name: "Elegir tipo de búsqueda", text: "Seleccioná entre placa, NIV (17 caracteres), folio de constancia o NCI." },
      { name: "Ingresar el dato del vehículo", text: "Escribí el dato SIN guiones ni espacios, todo en mayúsculas. Ejemplo de placa: ABC1234." },
      { name: "Resolver el captcha", text: "Completá el captcha que aparece. Si no se entiende, recargá la imagen." },
      { name: "Pulsar Buscar", text: "El sistema responde en 5-60 segundos con el estatus del vehículo." },
      { name: "Interpretar el resultado", text: "Sin reporte = limpio. Con reporte de robo = NO compres. Recuperado = verificá cadena legal. Sin información = puede no estar inscrito." }
    ]
  },
  'consulta-por-placa': {
    name: "Cómo consultar REPUVE por placa en Saltillo",
    description: "Verificá un vehículo usando solo el número de placa. Gratis, sin registro, resultado en 2 minutos.",
    totalTime: "PT2M",
    estimatedCost: { currency: "MXN", value: "0" },
    supply: ["Número de placa (5-7 caracteres alfanuméricos)"],
    tool: ["Dispositivo con internet"],
    steps: [
      { name: "Abrir portal REPUVE", text: "Ingresá a https://www2.repuve.gob.mx:8443/ciudadania/" },
      { name: "Seleccionar 'Consulta por placa'", text: "Es la primera opción del formulario, la más común." },
      { name: "Escribir la placa", text: "Sin guiones ni espacios. Ejemplo: ABC1234 (no ABC-1234)." },
      { name: "Resolver captcha", text: "Completá el captcha de validación." },
      { name: "Buscar y leer resultado", text: "Te devuelve datos del vehículo y estatus: 'sin reporte', 'con reporte de robo', 'recuperado' o 'sin información'." }
    ]
  },
  'consulta-por-niv': {
    name: "Cómo consultar REPUVE por NIV (VIN) en Saltillo",
    description: "Verificación más confiable que por placa. El NIV es único e invariable por vehículo durante toda su vida útil.",
    totalTime: "PT3M",
    estimatedCost: { currency: "MXN", value: "0" },
    supply: ["NIV/VIN del vehículo (17 caracteres exactos)"],
    tool: ["Dispositivo con internet"],
    steps: [
      { name: "Conseguir el NIV", text: "El NIV está en: parabrisas (esquina inferior conductor), puerta del piloto, tarjeta de circulación o factura. Son 17 caracteres alfanuméricos, sin letras I/O/Q." },
      { name: "Ingresar al portal oficial", text: "https://www2.repuve.gob.mx:8443/ciudadania/" },
      { name: "Seleccionar 'Consulta por NIV'", text: "En el formulario del portal." },
      { name: "Escribir el NIV completo", text: "Todo en mayúsculas, sin guiones ni espacios. 17 caracteres exactos." },
      { name: "Resolver captcha y buscar", text: "El sistema responde en 5-60 segundos." },
      { name: "Verificar coincidencia", text: "Los datos devueltos (marca, modelo, año, color) deben coincidir 100% con el vehículo físico. Si no coinciden, hay fraude." }
    ]
  },
  'agendar-cita': {
    name: "Cómo agendar cita REPUVE en Saltillo",
    description: "Reservá tu cita previa online para trámites presenciales (regularización, inscripción, cambio de propietario) en el Centro de Recaudación Saltillo o el Registro Estatal de Trámites.",
    totalTime: "PT15M",
    estimatedCost: { currency: "MXN", value: "0" },
    supply: ["CURP", "Correo electrónico", "Datos del vehículo (NIV, marca, modelo)", "Identificación oficial"],
    tool: ["Computadora o celular con internet", "Acceso a banco (para pagar línea de captura si aplica)"],
    steps: [
      { name: "Acceder a la plataforma oficial", text: "Para regularización: https://regularizaauto.sspc.gob.mx. Para otros trámites: llamar al 800 737 8831 o acudir directamente." },
      { name: "Crear cuenta o iniciar sesión", text: "Registrate con CURP, correo y teléfono." },
      { name: "Cargar datos del vehículo", text: "NIV de 17 caracteres, marca, modelo, año, color, placas (si tiene)." },
      { name: "Generar línea de captura", text: "Si aplica costo (ej: $2,500 MXN para regularización), el sistema genera una referencia bancaria." },
      { name: "Pagar en banco autorizado", text: "HSBC, Banamex, Banorte, BBVA, Santander o Scotiabank. Conservar comprobante." },
      { name: "Seleccionar módulo y fecha", text: "Elegí Centro de Recaudación Saltillo o Registro Estatal de Trámites, y la fecha/hora disponible." },
      { name: "Confirmar e imprimir", text: "Recibís correo de confirmación. Imprimí el comprobante o guardalo en celular para el día de la cita." }
    ]
  },
  'regularizacion-autos-chocolate': {
    name: "Cómo regularizar un auto chocolate en Saltillo, Coahuila",
    description: "Legalizá tu vehículo de procedencia extranjera ingresado antes del 19-oct-2021 bajo el Decreto Federal de Regularización. Costo único: $2,500 MXN. Resultado: chip REPUVE + posibilidad de emplacar en Coahuila.",
    totalTime: "P30D",
    estimatedCost: { currency: "MXN", value: "2500" },
    supply: [
      "Título original del país de origen (Title EE.UU.)",
      "INE vigente del propietario",
      "CURP",
      "Comprobante de domicilio reciente (≤3 meses)",
      "Manifiesto firmado en tinta azul",
      "2 fotografías del vehículo (parabrisas con NIV + puerta piloto)"
    ],
    tool: ["Vehículo físico para inspección", "Banco autorizado para pago", "Plataforma regularizaauto.sspc.gob.mx"],
    steps: [
      { name: "Verificar elegibilidad", text: "Tu auto debe haber ingresado al país antes del 19 de octubre de 2021 y tener Title original. Sin Title no podés regularizar." },
      { name: "Crear cuenta en plataforma federal", text: "Andá a regularizaauto.sspc.gob.mx y registrate con CURP, correo y teléfono." },
      { name: "Llenar formulario con datos del vehículo", text: "NIV (17 caracteres), marca, modelo, año, color, número de motor. Cuidadosamente — el NIV debe coincidir con el grabado en el vehículo." },
      { name: "Generar y pagar línea de captura", text: "$2,500 MXN en banco autorizado (HSBC, Banamex, Banorte, BBVA, Santander, Scotiabank). Conservar comprobante con sello." },
      { name: "Agendar cita en módulo", text: "Elegir el módulo en Saltillo (Centro de Recaudación) o cualquier otro de Coahuila. Imprimir comprobante." },
      { name: "Acudir el día de la cita con todo", text: "Llegar 30 min antes con: documentos completos, comprobante de pago, manifiesto firmado, 2 fotos, vehículo físico. El módulo: verifica NIV → cobra (si no pagaste antes) → instala chip RFID → emite constancia." },
      { name: "Tramitar placas estatales", text: "Con la constancia REPUVE, acudir a Control Vehicular de Coahuila para emplacar (~$2,000 MXN adicionales). Pagar refrendo anual del año en curso." }
    ]
  },
  'cambio-propietario': {
    name: "Cómo hacer cambio de propietario vehicular en Saltillo",
    description: "Transferí legalmente un vehículo usado a tu nombre dentro de los 30 días posteriores a la compraventa. Trámite obligatorio en Coahuila.",
    totalTime: "PT2H",
    estimatedCost: { currency: "MXN", value: "1800" },
    supply: [
      "Factura original con endoso completo del vendedor",
      "Tarjeta de circulación vigente",
      "Constancia REPUVE actualizada",
      "INE vigente (comprador y vendedor)",
      "CURP del comprador",
      "Comprobante de domicilio en Coahuila",
      "Refrendo y multas al corriente"
    ],
    tool: ["Vehículo físico", "Banco para pago de derechos"],
    steps: [
      { name: "Verificar el REPUVE antes de comprar", text: "Hacer consulta ciudadana por NIV y placa. Asegurarse de que no tiene reporte de robo ni alertas." },
      { name: "Verificar adeudos del vehículo", text: "Confirmar que el vendedor está al corriente con refrendo y multas. Si hay adeudos pendientes, el comprador los hereda." },
      { name: "Firmar la factura con endoso", text: "El vendedor firma el reverso de la factura indicando: nombre del comprador, fecha y firma. Sin este endoso no se puede hacer el cambio." },
      { name: "Reunir documentación", text: "INE del comprador y vendedor, CURP, comprobante de domicilio, factura endosada, tarjeta de circulación, constancia REPUVE." },
      { name: "Acudir al Registro Estatal de Trámites", text: "Saltillo (Bv. Fundadores). No requiere cita previa en la mayoría de casos. Llevar el vehículo físicamente." },
      { name: "Pagar derechos de cambio de propietario", text: "Aproximadamente $1,500-$2,200 MXN según modelo y año del vehículo." },
      { name: "Recibir nuevos documentos", text: "Te entregan nueva tarjeta de circulación a tu nombre y, según el caso, placas nuevas o las mismas." }
    ]
  }
};

const howtoConfig = HOWTO_BY_SLUG[page.slug];
if (howtoConfig) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": howtoConfig.name,
    "description": howtoConfig.description,
    "totalTime": howtoConfig.totalTime,
    "estimatedCost": {
      "@type": "MonetaryAmount",
      "currency": howtoConfig.estimatedCost.currency,
      "value": howtoConfig.estimatedCost.value
    },
    "supply": howtoConfig.supply.map((s: string) => ({ "@type": "HowToSupply", "name": s })),
    "tool": howtoConfig.tool.map((t: string) => ({ "@type": "HowToTool", "name": t })),
    "step": howtoConfig.steps.map((s: any, i: number) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "name": s.name,
      "text": s.text,
      "url": `https://${site.domain}/${page.slug}/#paso-${i + 1}`
    })),
    "inLanguage": "es-MX"
  });
}

// WebPage / Article schema
schemas.push({
  "@context": "https://schema.org",
  "@type": page.category === 'Informacion' ? "Article" : "WebPage",
  "headline": page.h1,
  "name": page.h1,
  "description": page.meta,
  "url": `https://${site.domain}/${page.slug}/`,
  "inLanguage": "es-MX",
  ...(page.category === 'Informacion' && {
    "author": { "@type": "Organization", "name": "REPUVE Saltillo (sitio informativo)" },
    "publisher": { "@type": "Organization", "name": "REPUVE Saltillo (sitio informativo)" }
  })
});

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: page.category || 'Información', href: undefined },
  { label: page.h1 }
];
---

<Base
  title={page.title}
  description={page.meta}
  schema={schemas}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />

    <header class="page-header">
      <div class="eyebrow">
        <i class={`fa-solid ${iconForCategory(page.category)}`} aria-hidden="true"></i>
        {page.category || 'Información'}
      </div>
      <h1>{page.h1}</h1>
      {page.status_chip && <span class="status-chip">{page.status_chip}</span>}
      <p class="lede" set:html={page.intro} />

      <div class="cta-row">
        <a href="/consulta-ciudadana/" class="btn btn-primary">
          <i class="fa-solid fa-magnifying-glass"></i> Consulta gratis
        </a>
        <a href={`tel:${site.phone_repuve.replace(/\s/g,'')}`} class="btn btn-secondary">
          <i class="fa-solid fa-phone"></i> {site.phone_repuve}
        </a>
      </div>
    </header>

    <div class="article-grid">
      <article class="article-main">
        {showForm && (
          <div style="margin-bottom: var(--space-7)">
            <ConsultaForm defaultTab={defaultTab} bg="light" />
          </div>
        )}

        <!-- DATOS CLAVE CARD con botones explícitos + amplitud semántica (verbos variados para SEO) -->
        <div class="key-info-card">
          <h3 class="key-info-title">
            <i class="fa-solid fa-circle-info"></i> Acciones rápidas REPUVE
          </h3>
          <div class="key-info-grid">

            {/* CARD 1: Llamada telefónica directa */}
            <a href={`tel:${site.phone_repuve.replace(/\s/g,'')}`} class="key-info-item" aria-label="Llamar a la línea nacional REPUVE">
              <div class="key-info-icon">
                <i class="fa-solid fa-phone"></i>
              </div>
              <div class="key-info-content">
                <div class="key-info-label">Línea REPUVE nacional</div>
                <div class="key-info-value">{site.phone_repuve}</div>
                <div class="key-info-desc">Atención gratuita 24/7</div>
              </div>
              <span class="key-info-btn">
                <i class="fa-solid fa-phone-volume"></i> Llamar ahora
              </span>
            </a>

            {/* CARD 2: Agendar cita (verbo: PEDIR/RESERVAR) */}
            <a href="/agendar-cita/" class="key-info-item" aria-label="Reservar cita en línea para trámite REPUVE">
              <div class="key-info-icon">
                <i class="fa-solid fa-calendar-check"></i>
              </div>
              <div class="key-info-content">
                <div class="key-info-label">Cita previa</div>
                <div class="key-info-value">Reserva en línea 24/7</div>
                <div class="key-info-desc">Para trámites presenciales</div>
              </div>
              <span class="key-info-btn">
                <i class="fa-solid fa-calendar-plus"></i> Pedir cita
              </span>
            </a>

